{
  "entities": {
    "Player": {
      "title": "Player",
      "description": "A football player in the club",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "number": { "type": "number" },
        "position": { "type": "string", "enum": ["Goalkeeper", "Defender", "Midfielder", "Striker"] },
        "photoUrl": { "type": "string" },
        "stats": {
          "type": "object",
          "properties": {
            "matchesPlayed": { "type": "number" },
            "goals": { "type": "number" },
            "assists": { "type": "number" },
            "rating": { "type": "number" }
          }
        }
      },
      "required": ["name", "number", "position"]
    },
    "Official": {
      "title": "Official",
      "description": "A club official (coach, manager, etc.)",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "role": { "type": "string" },
        "photoUrl": { "type": "string" },
        "contact": { "type": "string" }
      },
      "required": ["name", "role"]
    },
    "Match": {
      "title": "Match",
      "description": "A football match fixture or result",
      "type": "object",
      "properties": {
        "opponent": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "time": { "type": "string" },
        "venue": { "type": "string" },
        "competition": { "type": "string" },
        "status": { "type": "string", "enum": ["played", "upcoming"] },
        "score": {
          "type": "object",
          "properties": {
            "home": { "type": "number" },
            "away": { "type": "number" }
          }
        },
        "isHome": { "type": "boolean" }
      },
      "required": ["opponent", "date", "competition", "status", "isHome"]
    },
    "NewsItem": {
      "title": "News Item",
      "description": "A news article or announcement",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "imageUrl": { "type": "string" },
        "category": { "type": "string", "enum": ["Match Result", "Announcement", "Tournament", "Notice"] }
      },
      "required": ["title", "content", "date", "category"]
    },
    "GalleryItem": {
      "title": "Gallery Item",
      "description": "A photo in the club gallery",
      "type": "object",
      "properties": {
        "imageUrl": { "type": "string" },
        "category": { "type": "string", "enum": ["Match", "Training", "Celebrations"] },
        "date": { "type": "string", "format": "date" }
      },
      "required": ["imageUrl", "category", "date"]
    }
  },
  "firestore": {
    "/players/{playerId}": { "schema": "Player", "description": "Collection of players" },
    "/officials/{officialId}": { "schema": "Official", "description": "Collection of officials" },
    "/matches/{matchId}": { "schema": "Match", "description": "Collection of matches" },
    "/news/{newsId}": { "schema": "NewsItem", "description": "Collection of news items" },
    "/gallery/{photoId}": { "schema": "GalleryItem", "description": "Collection of gallery photos" }
  }
}
